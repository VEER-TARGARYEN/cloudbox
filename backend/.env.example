# Copy this file to ".env" and adjust as needed.
# (We load these as environment variables; see internal/config/config.go)

# HTTP port the API listens on
PORT=8080

# Path to the SQLite metadata database file
DATABASE_URL=./data/cloudbox.db

# Directory on your hard drive where the actual file blobs are stored
STORAGE_DIR=./storage

# Largest single upload accepted, in bytes (default 2 GiB = 2147483648)
MAX_UPLOAD_BYTES=2147483648

# Secret used to sign JWT auth tokens (Phase 2).
# Generate a long random value, e.g. in PowerShell:
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_SECRET=replace-with-a-long-random-string
