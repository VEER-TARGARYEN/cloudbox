# Copy to ".env". The broker is the always-on cloud directory service.
PORT=9000
DATABASE_URL=./data/broker.db

# Sign broker session tokens. Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-string

# The broker's own public URL (used to build email verification links).
PUBLIC_URL=https://your-broker.onrender.com

# SMTP for verification emails. Leave SMTP_HOST blank in dev — verification
# links are printed to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@yourdomain.com
