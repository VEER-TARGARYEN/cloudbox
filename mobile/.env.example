# Copy to ".env" and set your backend URL. Expo auto-loads EXPO_PUBLIC_* vars.
#
# Real device on your home Wi-Fi  -> your laptop's LAN IP:
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:8080
# From anywhere (Phase 6 tunnel)  -> your public HTTPS URL:
#   EXPO_PUBLIC_API_URL=https://your-tunnel.trycloudflare.com
EXPO_PUBLIC_API_URL=http://localhost:8080
