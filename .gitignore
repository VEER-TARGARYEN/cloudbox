# ───────────── Backend (Go) ─────────────
# Never commit user data or the database
/backend/storage/
/backend/data/
*.db
*.db-shm
*.db-wal

# Secrets
.env
backend/.env

# Compiled binaries
*.exe
/backend/cloudbox
/backend/server

# ───────────── Mobile (Expo / RN) ─────────────
/mobile/node_modules/
/mobile/.expo/
/mobile/dist/
/mobile/web-build/
npm-debug.*
yarn-error.*

# Native projects generated by `expo prebuild` / local EAS builds
/mobile/android/
/mobile/ios/

# Build artifacts & signing material — APKs ship via GitHub Releases, not git
*.apk
*.aab
*.keystore
*.jks

# Design reference: keep DESIGN.md, ignore bulky exports
/design/_extracted/
/design/*.zip

# Installer build artifacts (CloudBox-Setup.exe ships via GitHub Releases)
/installer/dist/
/installer/Output/

# ───────────── Editor / OS ─────────────
.DS_Store
.idea/
.vscode/
Thumbs.db
